%% aws-cloudops-private-ec2-operations-platform — Architecture overview
%% Renders inline in GitHub README. Source kept here for maintenance.

flowchart LR
    operator([Operator])
    iam[IAM + MFA]
    ssm[SSM Service]

    subgraph vpc[VPC 10.20.0.0/16 - us-east-1]
        direction TB

        subgraph endpoints[Endpoint subnets - private, 2 AZs]
            vpce_ssm[VPCE: ssm]
            vpce_ssmm[VPCE: ssmmessages]
            vpce_ec2m[VPCE: ec2messages]
            vpce_logs[VPCE: logs]
            vpce_mon[VPCE: monitoring]
            s3gw[S3 Gateway Endpoint]
        end

        subgraph workload[Workload subnets - private, 2 AZs]
            asg[Auto Scaling Group<br/>min=max=1]
            ec2[EC2 t4g.micro<br/>Golden AMI<br/>heartbeat-api]
        end

        flow[VPC Flow Logs<br/>ALL traffic]
    end

    cw[CloudWatch<br/>Logs + Metrics + Alarms]
    sns[SNS Topic]
    backup[AWS Backup<br/>Vault + Plan]
    kms[KMS CMK]
    ib[EC2 Image Builder<br/>Golden AMI Pipeline]
    s3diag[S3 Diagnostics Bucket<br/>SSE-KMS]
    ct[CloudTrail<br/>account-level, assumed]

    operator -->|aws ssm start-session| iam
    iam --> ssm
    ssm --> vpce_ssm
    vpce_ssm --> ec2
    vpce_ssmm --> ec2
    vpce_ec2m --> ec2
    ec2 -->|logs + metrics| vpce_logs
    ec2 --> vpce_mon
    vpce_logs --> cw
    vpce_mon --> cw
    cw -->|alarms| sns
    asg -.manages.-> ec2
    ec2 -.encrypted with.-> kms
    cw -.encrypted with.-> kms
    backup -.encrypted with.-> kms
    s3diag -.encrypted with.-> kms
    ec2 -.snapshotted by.-> backup
    ib -.publishes AMI ID to SSM Parameter.-> asg
    flow --> cw
    ec2 -->|diagnostics dump| s3gw
    s3gw --> s3diag
    iam -.audit trail.-> ct
