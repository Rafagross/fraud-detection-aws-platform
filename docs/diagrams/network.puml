@startuml network
!theme plain
title VPC Network Topology — cloudops-dev (us-east-1)

' Layout
left to right direction
skinparam roundCorner 10
skinparam shadowing false
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 11
skinparam ArrowColor #555555

' Color palette
skinparam package {
    BackgroundColor<<vpc>> #F0F4F8
    BorderColor<<vpc>> #4A6FA5
    BackgroundColor<<az>> #FFFFFF
    BorderColor<<az>> #888888
    BackgroundColor<<public>> #FFF4E6
    BorderColor<<public>> #D9822B
    BackgroundColor<<private>> #E6F4EA
    BorderColor<<private>> #2D8659
    BackgroundColor<<endpoint>> #E6EEF8
    BorderColor<<endpoint>> #4A6FA5
}

package "VPC: cloudops-dev-vpc-main\n10.20.0.0/16" <<vpc>> {

    package "Availability Zone us-east-1a" <<az>> {

        package "public-a (10.20.0.0/24)\nRESERVED — no IGW in MVP" <<public>> {
            note as nA1
                No instances
                No IGW route
            end note
        }

        package "private-app-a (10.20.10.0/24)" <<private>> {
            component "ASG instance\n(eligible)" as ec2a
        }

        package "private-vpce-a (10.20.20.0/24)" <<endpoint>> {
            component "VPCE ENI\n(ssm, ssmmessages,\nec2messages, logs,\nmonitoring)" as vpcea
        }
    }

    package "Availability Zone us-east-1b" <<az>> {

        package "public-b (10.20.1.0/24)\nRESERVED — no IGW in MVP" <<public>> {
            note as nB1
                No instances
                No IGW route
            end note
        }

        package "private-app-b (10.20.11.0/24)" <<private>> {
            component "ASG instance\n(eligible)" as ec2b
        }

        package "private-vpce-b (10.20.21.0/24)" <<endpoint>> {
            component "VPCE ENI\n(ssm, ssmmessages,\nec2messages, logs,\nmonitoring)" as vpceb
        }
    }

    component "S3 Gateway Endpoint\n(route in private RTs)" as s3gw

    note as nRT
        Route tables (private):
        • Local: 10.20.0.0/16
        • S3 prefix list -> S3 GW Endpoint
        • NO 0.0.0.0/0 route
        • NO IGW, NO NAT
    end note

    note as nFL
        VPC Flow Logs:
        • Capture: ALL traffic
        • Destination: CloudWatch Logs
        • Retention: 14 days
        • Encryption: platform CMK
    end note

    note as nSG
        Security Groups:
        • sg-workload: NO inbound,
          egress 443 to sg-vpce + S3 PL
        • sg-vpce: 443 from sg-workload,
          NO egress
    end note
}

cloud "AWS Service Plane\n(SSM, CloudWatch, S3, KMS,\nAWS Backup, Image Builder)" as awsplane

ec2a -[#2D8659,bold]-> vpcea : 443
ec2b -[#2D8659,bold]-> vpceb : 443
ec2a -[#2D8659,bold]-> s3gw : 443
ec2b -[#2D8659,bold]-> s3gw : 443
vpcea -[#4A6FA5,dashed]-> awsplane : PrivateLink
vpceb -[#4A6FA5,dashed]-> awsplane : PrivateLink
s3gw -[#4A6FA5,dashed]-> awsplane

@enduml
