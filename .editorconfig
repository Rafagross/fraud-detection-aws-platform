# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.tf]
indent_size = 2

[*.tfvars]
indent_size = 2

[*.yaml]
indent_size = 2

[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab
